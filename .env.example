# Chip Brain — Environment Configuration (all optional)
# Copy this to .env and uncomment what you need.

# Force a specific compute device (auto-detected if not set)
# Options: auto, cuda, directml, mps, cpu
# CHIP_DEVICE=auto

# HuggingFace token (only needed if you hit rate limits downloading Granite)
# Get one at: https://huggingface.co/settings/tokens
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# Suppress HuggingFace symlink warnings on Windows
HF_HUB_DISABLE_SYMLINKS_WARNING=1

# Reduce transformer library log noise
TRANSFORMERS_VERBOSITY=error
